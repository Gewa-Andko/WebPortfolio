# ============================================
# NGINX SITE CONFIG - CVG Portfolio
# Untuk CasaOS (LinuxServer.io nginx base)
# Letakkan di: /config/nginx/site-confs/
# ============================================

server {
    # CasaOS biasanya listen di port 81 atau 82
    # Cek di pengaturan CasaOS kamu
    listen 81;
    listen [::]:81;

    # Domain dari Cloudflare
    server_name gewa.my.id www.gewa.my.id;

    # Root folder website - sesuaikan path appdata kamu
    root /config/www/cvg;
    index index.html;

    # ============================================
    # CLOUDFLARE - Real IP
    # ============================================
    set_real_ip_from 103.21.244.0/22;
    set_real_ip_from 103.22.200.0/22;
    set_real_ip_from 103.31.4.0/22;
    set_real_ip_from 104.16.0.0/13;
    set_real_ip_from 104.24.0.0/14;
    set_real_ip_from 108.162.192.0/18;
    set_real_ip_from 131.0.72.0/22;
    set_real_ip_from 141.101.64.0/18;
    set_real_ip_from 162.158.0.0/15;
    set_real_ip_from 172.64.0.0/13;
    set_real_ip_from 173.245.48.0/20;
    set_real_ip_from 188.114.96.0/20;
    set_real_ip_from 190.93.240.0/20;
    set_real_ip_from 197.234.240.0/22;
    set_real_ip_from 198.41.128.0/17;
    set_real_ip_from 2400:cb00::/32;
    set_real_ip_from 2606:4700::/32;
    set_real_ip_from 2803:f800::/32;
    set_real_ip_from 2405:b500::/32;
    set_real_ip_from 2405:8100::/32;
    set_real_ip_from 2a06:98c0::/29;
    set_real_ip_from 2c0f:f250::/32;
    real_ip_header CF-Connecting-IP;
    real_ip_recursive on;

    # ============================================
    # SECURITY HEADERS
    # ============================================
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=()" always;

    # ============================================
    # ANTI-HOTLINKING - Proteksi Gambar
    # Cegah domain lain menggunakan gambar kita
    # ============================================
    location ~* \.(jpg|jpeg|png|gif|ico|webp|svg)$ {
        # Izinkan akses langsung dan dari domain sendiri
        valid_referers none blocked server_names ~\.gewa\.my\.id;

        if ($invalid_referer) {
            return 403;
        }

        expires 1y;
        add_header Cache-Control "public, no-transform, immutable";
        access_log off;
    }

    # Proteksi folder image
    location /image/ {
        valid_referers none blocked server_names ~\.gewa\.my\.id;

        if ($invalid_referer) {
            return 403;
        }

        autoindex off;
    }

    # ============================================
    # BROWSER CACHING
    # ============================================
    # CSS & JS - 1 bulan
    location ~* \.(css|js)$ {
        expires 1M;
        add_header Cache-Control "public, no-transform";
        access_log off;
    }

    # Fonts - 1 tahun
    location ~* \.(woff|woff2|ttf|eot)$ {
        expires 1y;
        add_header Cache-Control "public, no-transform, immutable";
        access_log off;
    }

    # ============================================
    # PROXY BACKEND (Node.js API)
    # Untuk verifikasi email - aktifkan saat backend jalan
    # ============================================
    location /api/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;

        # Timeout
        proxy_connect_timeout 10s;
        proxy_send_timeout 10s;
        proxy_read_timeout 10s;
    }

    # ============================================
    # MAIN HTML - No Cache
    # ============================================
    location / {
        try_files $uri $uri/ /index.html;
        expires -1;
        add_header Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate";
    }

    # ============================================
    # DENY ACCESS - Proteksi file sensitif
    # ============================================
    # File tersembunyi ( .env, .git, dll )
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }

    # Folder backend
    location /backend/ {
        deny all;
        access_log off;
        log_not_found off;
    }
}