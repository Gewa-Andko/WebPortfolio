# ============================================
# EMAIL CONFIGURATION
# ============================================

# Gmail SMTP (gunakan App Password, bukan password biasa)
# Cara buat App Password: https://myaccount.google.com/apppasswords
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-16-digit

# Email tujuan untuk menerima notifikasi pesan kontak
RECEIVER_EMAIL=your-email@gmail.com

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3000

# ============================================
# SECURITY
# ============================================
CORS_ORIGIN=http://localhost:5500
# Ganti dengan domain asli saat deploy, misal:
# CORS_ORIGIN=https://gewa.my.id